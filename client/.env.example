# Leave VITE_API_URL as /api in development — Vite proxy forwards to server.
# In production, set to your deployed server URL e.g. https://api.yourapp.com/api
VITE_API_URL=/api

# Leave VITE_SERVER_URL empty in development — Vite proxy handles /socket.io.
# In production, set to your server origin e.g. https://api.yourapp.com
VITE_SERVER_URL=

# Google OAuth Client ID (optional — only needed for Google sign-in)
VITE_GOOGLE_CLIENT_ID=your-google-client-id-here

# Giphy API key (optional — enables the GIF picker; free at developers.giphy.com)
VITE_GIPHY_API_KEY=your-giphy-api-key-here
